{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipDefaultLibCheck": true,
    "types": [],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/main/**/*"],
  "exclude": ["node_modules", "dist"]
}
