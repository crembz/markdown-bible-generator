{
  "name": "markdown-bible-generator",
  "version": "1.0.0",
  "description": "Desktop app that downloads Bible translations from bolls.life and generates markdown output",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "tsc && copy-renderer && electron .",
    "package": "electron-builder",
    "copy-renderer": "node -e \"const fs=require('fs'),path=require('path');fs.readdirSync('src/renderer').forEach(f=>fs.copyFileSync('src/renderer/'+f,'dist/renderer/'+f))\""
  },
  "build": {
    "appId": "com.markdownbiblegenerator.app",
    "productName": "Markdown Bible Generator",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12"
  }
}
