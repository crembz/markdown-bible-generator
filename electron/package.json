{
  "name": "markdown-bible-generator",
  "version": "1.0.1",
  "description": "Desktop app that downloads Bible translations from bolls.life and generates markdown output",
  "author": "crembz",
  "repository": {
    "type": "git",
    "url": "https://github.com/crembz/markdown-bible-generator.git"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "tsc && node scripts/copy-renderer.js && electron .",
    "package": "electron-builder",
    "copy-renderer": "node scripts/copy-renderer.js"
  },
  "build": {
    "appId": "com.markdownbiblegenerator.app",
    "productName": "Markdown Bible Generator",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*"
    ]
  },
  "publish": {
    "provider": "github",
    "repo": "markdown-bible-generator",
    "owner": "crembz",
    "releaseType": "release"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12"
  },
  "allowScripts": {
    "electron@28.3.3": true,
    "electron-winstaller@5.4.0": true
  }
}